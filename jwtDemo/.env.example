# Copy this file, rename it to .env and fill in your real values
# Never commit .env to GitHub — only .env.example goes to GitHub

JWT_SECRET=your_base64_secret_here_run_openssl_rand_base64_32
JWT_EXPIRATION_MS=3600000

DB_URL=jdbc:mysql://localhost:3306/jwtdb
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

RAZORPAY_KEY_ID=your_razorpay_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_CURRENCY=INR
